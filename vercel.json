{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/alerts",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/batch/run",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/stat-daily",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/stat-hourly",
      "schedule": "5 * * * *"
    }
  ]
}
