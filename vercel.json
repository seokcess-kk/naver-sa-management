{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/alerts",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/batch/run",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/stat-daily",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/stat-hourly",
      "schedule": "5 * * * *"
    },
    {
      "path": "/api/cron/stat-cleanup",
      "schedule": "30 18 * * *"
    },
    {
      "path": "/api/cron/auto-bidding",
      "schedule": "10 * * * *"
    },
    {
      "path": "/api/cron/sync-all",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/keyword-perf-profile",
      "schedule": "30 19 * * *"
    },
    {
      "path": "/api/cron/bid-suggest",
      "schedule": "20 * * * *"
    },
    {
      "path": "/api/cron/quality-monitor",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/targeting-tuner",
      "schedule": "30 18 * * 1"
    },
    {
      "path": "/api/cron/llm-daily-summary",
      "schedule": "0 0 * * *"
    }
  ]
}
