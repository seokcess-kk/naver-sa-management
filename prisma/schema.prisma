// Prisma schema — 네이버 검색광고 다계정 운영 어드민
// SPEC v0.2.1 9장(데이터 모델)이 단일 진실 원천.
// P1 핵심 엔티티 + StatDaily 선언. P2 엔티티는 주석으로 표시만.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
  // Prisma 7부터 driver adapter는 정식 지원(preview feature 불필요).
  // 런타임은 lib/db/prisma.ts 에서 @prisma/adapter-pg 주입.
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  admin
  operator
  viewer
}

enum UserStatus {
  active
  disabled
}

enum AdvertiserStatus {
  active
  paused
  archived
}

enum CampaignStatus {
  on
  off
  deleted
}

enum AdGroupStatus {
  on
  off
  deleted
}

enum KeywordStatus {
  on
  off
  deleted
}

enum AdStatus {
  on
  off
  deleted
}

enum AdExtensionStatus {
  on
  off
  deleted
}

enum InspectStatus {
  pending
  approved
  rejected
}

enum AdExtensionType {
  // P1 — 3종
  headline // 추가제목
  description // 추가설명
  image // 이미지
  // P2+ (모델은 수용 가능, 기능 구현은 추후)
  pricelink
  sublink
  location
  calculation
  reservation
  talktalk
}

enum ChangeBatchStatus {
  pending
  running
  done
  failed
  canceled
}

enum ChangeItemStatus {
  pending
  running
  done
  failed
  skipped
}

enum StatLevel {
  campaign
  adgroup
  keyword
}

enum StatDevice {
  PC
  MOBILE
  // F-9.2: StatHourly 적재는 Stats API hh24 breakdown 만 사용 (시간 분해).
  // Stats API 의 hh24 와 pcMblTp 동시 breakdown 은 미지원으로 관찰됨 → 시간×디바이스
  // 분해는 P2 후속에서 결정. StatHourly 는 device='ALL' 단일 행으로 적재한다.
  // StatDaily 는 PC/MOBILE 만 사용 (코드 정책). DB 레벨 enum 분리 강제는 하지 않음.
  ALL
}

enum AlertEventStatus {
  pending
  sent
  failed
  muted
}

// =============================================================================
// 사용자 / 권한
// =============================================================================

// id = Supabase Auth user.id (UUID 문자열)
model UserProfile {
  id          String     @id
  displayName String
  role        UserRole   @default(viewer)
  status      UserStatus @default(active)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  advertiserAccess UserAdvertiserAccess[] @relation("UserProfileAccess")
  grantedAccess    UserAdvertiserAccess[] @relation("UserProfileGrantor")
  changeBatches    ChangeBatch[]
  auditLogs        AuditLog[]
}

model UserAdvertiserAccess {
  id           String   @id @default(cuid())
  userId       String
  advertiserId String
  grantedBy    String?
  grantedAt    DateTime @default(now())

  user       UserProfile  @relation("UserProfileAccess", fields: [userId], references: [id], onDelete: Cascade)
  grantor    UserProfile? @relation("UserProfileGrantor", fields: [grantedBy], references: [id], onDelete: SetNull)
  advertiser Advertiser   @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  @@unique([userId, advertiserId])
  @@index([advertiserId])
}

// =============================================================================
// 광고주 (모델 2: 평면 구조)
// =============================================================================
// 모델 2: 광고주별 API 키·시크릿을 직접 발급받아 저장. MCC 마스터 권한 불필요.
// 시크릿은 평문 컬럼 금지 — AES-256-GCM 암호화 + 키 버전 컬럼 쌍.

model Advertiser {
  id               String           @id @default(cuid())
  customerId       String           @unique // 네이버 광고주 customerId
  name             String
  bizNo            String?
  category         String?
  manager          String?
  memo             String?          @db.VarChar(500) // 자유 메모 (선택, max 500자)
  tags             String[]         @default([])
  status           AdvertiserStatus @default(active)
  // 모델 2: 광고주별 API 키·시크릿. F-1.2(CSV 일괄 등록)는 메타만 등록하고
  // 시크릿은 별도 화면에서 입력 → enc 컬럼은 nullable.
  // 키가 null이면 SA API 호출 불가 (credentials.ts에서 "Credentials not set" throw).
  // 버전 컬럼은 default 1 유지 (enc 채워질 때 의미 발생).
  apiKeyEnc        Bytes?
  apiKeyVersion    Int              @default(1)
  secretKeyEnc     Bytes?
  secretKeyVersion Int              @default(1)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  campaigns   Campaign[]
  access      UserAdvertiserAccess[]
  stats       StatDaily[]
  statsHourly StatHourly[]

  @@index([customerId])
  @@index([status])
}

// =============================================================================
// 광고 구조 (네이버 SA)
// =============================================================================

model Campaign {
  id            String         @id @default(cuid())
  advertiserId  String
  nccCampaignId String         @unique
  name          String
  campaignType  String?
  dailyBudget   Decimal?       @db.Decimal(14, 2)
  status        CampaignStatus @default(on)
  raw           Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  advertiser Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  adgroups   AdGroup[]

  @@index([advertiserId])
}

model AdGroup {
  id           String        @id @default(cuid())
  campaignId   String
  nccAdgroupId String        @unique
  name         String
  bidAmt       Int?
  dailyBudget  Decimal?      @db.Decimal(14, 2)
  pcChannelOn  Boolean       @default(true)
  mblChannelOn Boolean       @default(true)
  status       AdGroupStatus @default(on)
  raw          Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  campaign   Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  keywords   Keyword[]
  ads        Ad[]
  extensions AdExtension[]

  @@index([campaignId])
}

model Keyword {
  id             String        @id @default(cuid())
  adgroupId      String
  nccKeywordId   String        @unique
  keyword        String
  matchType      String? // EXACT / PHRASE / BROAD
  bidAmt         Int?
  useGroupBidAmt Boolean       @default(true)
  userLock       Boolean       @default(false)
  externalId     String? // 사용자 멱등키 (CSV CREATE)
  status         KeywordStatus @default(on)
  inspectStatus  InspectStatus @default(pending)
  recentAvgRnk   Decimal?      @db.Decimal(5, 2)
  raw            Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  adgroup AdGroup @relation(fields: [adgroupId], references: [id], onDelete: Cascade)

  @@index([adgroupId, status])
}

model Ad {
  id            String        @id @default(cuid())
  adgroupId     String
  nccAdId       String        @unique
  adType        String?
  fields        Json? // 소재 텍스트/URL 등
  inspectStatus InspectStatus @default(pending)
  inspectMemo   String?
  status        AdStatus      @default(on)
  raw           Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  adgroup AdGroup @relation(fields: [adgroupId], references: [id], onDelete: Cascade)

  @@index([adgroupId])
}

model AdExtension {
  id            String            @id @default(cuid())
  ownerId       String // adgroupId 또는 campaignId 등
  ownerType     String            @default("adgroup")
  nccExtId      String            @unique
  type          AdExtensionType
  payload       Json
  periodStart   DateTime?
  periodEnd     DateTime?
  inspectStatus InspectStatus     @default(pending)
  inspectMemo   String?
  status        AdExtensionStatus @default(on)
  raw           Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // P1: ownerType=adgroup 가정. 향후 폴리모픽 확장 시 owner relation은 명시적 join으로 처리.
  adgroup AdGroup? @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, type])
}

// =============================================================================
// 변경 이력 / 감사
// =============================================================================

model ChangeBatch {
  id             String            @id @default(cuid())
  userId         String?
  action         String // 예: "keyword.bulk_off", "ad.bulk_update"
  status         ChangeBatchStatus @default(pending)
  total          Int               @default(0)
  processed      Int               @default(0)
  summary        Json?
  // Lease (3.5절 동시 실행 방지)
  leaseOwner     String?
  leaseExpiresAt DateTime?
  attempt        Int               @default(0)
  cursor         String? // 진단용
  createdAt      DateTime          @default(now())
  finishedAt     DateTime?

  user  UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)
  items ChangeItem[]

  @@index([status, leaseExpiresAt])
  @@index([userId])
}

model ChangeItem {
  id             String           @id @default(cuid())
  batchId        String
  targetType     String // "Keyword" / "Ad" / "AdExtension" / "Campaign" / "AdGroup"
  targetId       String? // 네이버 nccId 또는 내부 id (CREATE 전엔 null 가능)
  before         Json?
  after          Json?
  status         ChangeItemStatus @default(pending)
  error          String?
  idempotencyKey String // 사용자 externalId 또는 자체 생성
  attempt        Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  batch ChangeBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, idempotencyKey])
  @@index([batchId, status])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  targetType String
  targetId   String?
  before     Json?
  after      Json?
  ts         DateTime @default(now())

  user UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, ts])
  @@index([targetType, targetId])
}

// =============================================================================
// 알림 (P1)
// =============================================================================

model AlertRule {
  id          String   @id @default(cuid())
  type        String // budget_burn / bizmoney_low / api_auth_error / inspect_rejected ...
  params      Json
  channelHint String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events AlertEvent[]
}

model AlertEvent {
  id        String           @id @default(cuid())
  ruleId    String
  payload   Json
  status    AlertEventStatus @default(pending)
  sentAt    DateTime?
  createdAt DateTime         @default(now())

  rule AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, createdAt])
}

// =============================================================================
// 성과 데이터
// =============================================================================
// P1은 Stats API + Redis 캐시로 대체 (자체 적재 X 또는 최소).
// StatDaily는 P1에서 모델만 선언. 적재 빈도/매출 조인은 P2에서 결정.
// conversions / revenue는 매출 조인 시점에 채움.

model StatDaily {
  id           String     @id @default(cuid())
  // F-9.1: advertiserId 비정규화 — refId는 level별로 다른 엔티티(campaign/adgroup/keyword)의
  // 내부 id이므로 광고주 격리 / 단일 필터 KPI / RLS 단순화 위해 직접 보존.
  // 적재 시 refId의 owner advertiser를 resolve하여 함께 채운다 (NOT NULL).
  advertiserId String
  date         DateTime   @db.Date
  level        StatLevel
  refId        String // campaignId / adgroupId / keywordId (네이버 nccId 또는 내부 id 통일)
  device       StatDevice
  impressions  Int        @default(0)
  clicks       Int        @default(0)
  cost         Decimal    @default(0) @db.Decimal(14, 2)
  avgRnk       Decimal?   @db.Decimal(5, 2)
  // 매출/전환 조인은 P2 후속 (CRM·매출 시스템 연동 시점)에 채움
  conversions  Int?
  revenue      Decimal?   @db.Decimal(14, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  advertiser Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  @@unique([date, level, refId, device])
  // 광고주 + 기간 KPI 카드(F-7.1) / TOP-N 차트(F-7.2)
  @@index([advertiserId, date])
  // 광고주 + 레벨별 차트 (예: 광고주 N의 keyword level 30일 추이)
  @@index([advertiserId, level, date])
  // 적재 / 디버깅용 — 기존 인덱스 유지
  @@index([date, level, refId])
}

// F-9.2 — 시간별 적재 (P2 두 번째 적재 모델)
// 네이버 Stats API 의 시간별 데이터는 7일 보존 한계 → 자체 누적 필요.
// hh24 breakdown 으로 매시간 폴링 + upsert. KST 기준 (date Date + hour Int 0..23)
// 으로 시간대 정합성 단순화 (단일 timestamp 컬럼은 timezone 처리 모호함 회피).
//
// device 정책:
//   - 본 모델은 ALL 단일 디바이스로만 적재 (hh24 + pcMblTp 동시 breakdown 미지원).
//   - 시간×디바이스 분해가 필요해지면 device 컬럼은 그대로 두고 PC/MOBILE 적재 추가.
//   - device 컬럼을 unique 키에 포함해 두어 향후 확장 안전.
//
// retention 권고:
//   - 광고주 N × 24시간 × ~5,000 ref × 1 device(ALL) → 1년 후 ≈ 수억~수십억 rows.
//   - 90일 보관 cleanup cron 후속 PR 권고 (비딩 정책 / 알림 lookback 30일 가정).
//   - 본 PR 은 모델만 — retention 작업은 운영 부하 측정 후 결정.
model StatHourly {
  id           String     @id @default(cuid())
  // F-9.1 StatDaily 와 동일 비정규화 패턴 — 광고주 단일 필터 / Cascade / RLS 단순화.
  advertiserId String
  date         DateTime   @db.Date // KST 기준 일자
  hour         Int // 0..23 (KST 시각)
  level        StatLevel
  refId        String // campaignId / adgroupId / keywordId (네이버 nccId 또는 내부 id)
  device       StatDevice // 본 PR: 'ALL' 만 사용 (hh24 단일 breakdown). 향후 PC/MOBILE 분리 적재 시 enum 그대로 사용.
  impressions  Int        @default(0)
  clicks       Int        @default(0)
  cost         Decimal    @default(0) @db.Decimal(14, 2)
  // F-9.4 1시간 주기 갱신 입력 (Keyword.recentAvgRnk 갱신 원천 — keyword level 행 한정)
  recentAvgRnk Decimal?   @db.Decimal(5, 2)
  // 매출/전환 / raw 는 본 PR 비포함 — 시간별 매출 조인은 P2 후속 결정
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  advertiser Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  // 시간×레벨×ref×device 한 행 보장 (upsert 키)
  @@unique([date, hour, level, refId, device])
  // 광고주 + 시간 윈도 read (F-9.2 ingest cursor / F-7 시간별 차트)
  @@index([advertiserId, date, hour])
  // 광고주 + 레벨별 시간 차트 (예: 광고주 N의 keyword level 24h 추이)
  @@index([advertiserId, level, date, hour])
  // 적재 / 디버깅용 — 특정 ref 의 시간 추이
  @@index([date, hour, level, refId])
}

// =============================================================================
// P2 엔티티 (선언 보류 — 작업 시점에 추가)
// =============================================================================
// model BiddingPolicy   { ... } // 키워드별 목표 순위
// model OptimizationRun { ... } // 자동 비딩 실행 기록
// model EstimateCache   { ... } // Estimate API 결과 30분 캐시
// model RankObservation { ... } // 시간별 순위 관측
// model LlmCallLog      { ... } // LLM 호출 비용
