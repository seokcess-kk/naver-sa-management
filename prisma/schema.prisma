// Prisma schema — 네이버 검색광고 다계정 운영 어드민
// SPEC v0.2.1 9장(데이터 모델)이 단일 진실 원천.
// P1 핵심 엔티티 + StatDaily 선언. P2 엔티티는 주석으로 표시만.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
  // Prisma 7부터 driver adapter는 정식 지원(preview feature 불필요).
  // 런타임은 lib/db/prisma.ts 에서 @prisma/adapter-pg 주입.
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  admin
  operator
  viewer
}

enum UserStatus {
  active
  disabled
}

enum AdvertiserStatus {
  active
  paused
  archived
}

enum CampaignStatus {
  on
  off
  deleted
}

enum AdGroupStatus {
  on
  off
  deleted
}

enum KeywordStatus {
  on
  off
  deleted
}

enum AdStatus {
  on
  off
  deleted
}

enum AdExtensionStatus {
  on
  off
  deleted
}

enum InspectStatus {
  pending
  approved
  rejected
}

enum AdExtensionType {
  // P1 — 3종
  headline // 추가제목
  description // 추가설명
  image // 이미지
  // P2+ (모델은 수용 가능, 기능 구현은 추후)
  pricelink
  sublink
  location
  calculation
  reservation
  talktalk
}

enum ChangeBatchStatus {
  pending
  running
  done
  failed
  canceled
}

enum ChangeItemStatus {
  pending
  running
  done
  failed
  skipped
}

enum StatLevel {
  campaign
  adgroup
  keyword
}

enum StatDevice {
  PC
  MOBILE
  // F-9.2: StatHourly 적재는 Stats API hh24 breakdown 만 사용 (시간 분해).
  // Stats API 의 hh24 와 pcMblTp 동시 breakdown 은 미지원으로 관찰됨 → 시간×디바이스
  // 분해는 P2 후속에서 결정. StatHourly 는 device='ALL' 단일 행으로 적재한다.
  // StatDaily 는 PC/MOBILE 만 사용 (코드 정책). DB 레벨 enum 분리 강제는 하지 않음.
  ALL
}

enum AlertEventStatus {
  pending
  sent
  failed
  muted
}

// F-10 — Estimate API 결과 캐시 type 분기 (3개 endpoint)
//   - average_position : 키워드 + 순위(1..5) → 입찰가 (F-10.1)
//   - exposure_minimum : 키워드 → 최소 노출 입찰가 (F-10.2)
//   - performance_bulk : 키워드 + 입찰가 후보 → 예상 노출/클릭/CPC (F-10.3)
enum EstimateType {
  average_position
  exposure_minimum
  performance_bulk
}

// =============================================================================
// 사용자 / 권한
// =============================================================================

// id = Supabase Auth user.id (UUID 문자열)
model UserProfile {
  id          String     @id
  displayName String
  role        UserRole   @default(viewer)
  status      UserStatus @default(active)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  advertiserAccess UserAdvertiserAccess[] @relation("UserProfileAccess")
  grantedAccess    UserAdvertiserAccess[] @relation("UserProfileGrantor")
  changeBatches    ChangeBatch[]
  auditLogs        AuditLog[]
}

model UserAdvertiserAccess {
  id           String   @id @default(cuid())
  userId       String
  advertiserId String
  grantedBy    String?
  grantedAt    DateTime @default(now())

  user       UserProfile  @relation("UserProfileAccess", fields: [userId], references: [id], onDelete: Cascade)
  grantor    UserProfile? @relation("UserProfileGrantor", fields: [grantedBy], references: [id], onDelete: SetNull)
  advertiser Advertiser   @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  @@unique([userId, advertiserId])
  @@index([advertiserId])
}

// =============================================================================
// 광고주 (모델 2: 평면 구조)
// =============================================================================
// 모델 2: 광고주별 API 키·시크릿을 직접 발급받아 저장. MCC 마스터 권한 불필요.
// 시크릿은 평문 컬럼 금지 — AES-256-GCM 암호화 + 키 버전 컬럼 쌍.

model Advertiser {
  id                            String           @id @default(cuid())
  customerId                    String           @unique // 네이버 광고주 customerId
  name                          String
  bizNo                         String?
  category                      String?
  manager                       String?
  memo                          String?          @db.VarChar(500) // 자유 메모 (선택, max 500자)
  tags                          String[]         @default([])
  status                        AdvertiserStatus @default(active)
  // 모델 2: 광고주별 API 키·시크릿. F-1.2(CSV 일괄 등록)는 메타만 등록하고
  // 시크릿은 별도 화면에서 입력 → enc 컬럼은 nullable.
  // 키가 null이면 SA API 호출 불가 (credentials.ts에서 "Credentials not set" throw).
  // 버전 컬럼은 default 1 유지 (enc 채워질 때 의미 발생).
  apiKeyEnc                     Bytes?
  apiKeyVersion                 Int              @default(1)
  secretKeyEnc                  Bytes?
  secretKeyVersion              Int              @default(1)
  // F-11.6 — 비딩 자동화 Kill Switch (광고주 단위).
  //   true 이면 본 광고주의 자동 비딩 / 룰 트리거 / OptimizationRun 신규 실행 모두 차단.
  //   토글 메타 (At / By) 는 감사 추적 — 누가 언제 정지·재개했는지 기록.
  //   전역 Kill Switch 는 본 PR 비포함 (admin 환경변수로 후속 검토).
  biddingKillSwitch             Boolean          @default(false)
  biddingKillSwitchAt           DateTime?
  biddingKillSwitchBy           String? // 마지막 토글한 user.id (UserProfile.id)
  // F-11.5 — Guardrail (자동 비딩 폭주 방지). 광고주 단위 + 키워드 단위 한도.
  //   guardrailEnabled=false 이면 본 광고주의 가드레일 검사 자체를 스킵 (긴급 운영 시).
  //   maxBidChangePct: 1회 자동 조정에서 입찰가 ±N% 초과 변경 차단 (1..100, 기본 20).
  //   maxChangesPerKeyword: 키워드별 24h 내 OptimizationRun(result=success) 횟수 한도 (1..20, 기본 3).
  //   maxChangesPerDay: 광고주별 24h 내 총 변경 횟수 한도 (1..1000, 기본 50).
  //   범위 검증은 호출부 Zod (UpdateAdvertiserGuardrail) 에서 강제. DB 는 default 만 강제.
  //   룰(BiddingPolicy) 단위 한도는 본 PR 비포함 — 운영 데이터 누적 후 재검토.
  guardrailEnabled              Boolean          @default(true)
  guardrailMaxBidChangePct      Int              @default(20)
  guardrailMaxChangesPerKeyword Int              @default(3)
  guardrailMaxChangesPerDay     Int              @default(50)
  createdAt                     DateTime         @default(now())
  updatedAt                     DateTime         @updatedAt

  campaigns        Campaign[]
  access           UserAdvertiserAccess[]
  stats            StatDaily[]
  statsHourly      StatHourly[]
  estimateCaches   EstimateCache[]
  biddingPolicies  BiddingPolicy[]
  optimizationRuns OptimizationRun[]
  targetingRule    TargetingRule? // F-11.4 — 광고주 1:1

  @@index([customerId])
  @@index([status])
}

// =============================================================================
// 광고 구조 (네이버 SA)
// =============================================================================

model Campaign {
  id            String         @id @default(cuid())
  advertiserId  String
  nccCampaignId String         @unique
  name          String
  campaignType  String?
  dailyBudget   Decimal?       @db.Decimal(14, 2)
  status        CampaignStatus @default(on)
  raw           Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  advertiser Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  adgroups   AdGroup[]

  @@index([advertiserId])
}

model AdGroup {
  id           String        @id @default(cuid())
  campaignId   String
  nccAdgroupId String        @unique
  name         String
  bidAmt       Int?
  dailyBudget  Decimal?      @db.Decimal(14, 2)
  pcChannelOn  Boolean       @default(true)
  mblChannelOn Boolean       @default(true)
  status       AdGroupStatus @default(on)
  raw          Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  campaign   Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  keywords   Keyword[]
  ads        Ad[]
  extensions AdExtension[]

  @@index([campaignId])
}

model Keyword {
  id             String        @id @default(cuid())
  adgroupId      String
  nccKeywordId   String        @unique
  keyword        String
  matchType      String? // EXACT / PHRASE / BROAD
  bidAmt         Int?
  useGroupBidAmt Boolean       @default(true)
  userLock       Boolean       @default(false)
  externalId     String? // 사용자 멱등키 (CSV CREATE)
  status         KeywordStatus @default(on)
  inspectStatus  InspectStatus @default(pending)
  recentAvgRnk   Decimal?      @db.Decimal(5, 2)
  raw            Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  adgroup         AdGroup         @relation(fields: [adgroupId], references: [id], onDelete: Cascade)
  estimateCaches  EstimateCache[]
  biddingPolicies BiddingPolicy[]

  @@index([adgroupId, status])
}

model Ad {
  id            String        @id @default(cuid())
  adgroupId     String
  nccAdId       String        @unique
  adType        String?
  fields        Json? // 소재 텍스트/URL 등
  inspectStatus InspectStatus @default(pending)
  inspectMemo   String?
  status        AdStatus      @default(on)
  raw           Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  adgroup AdGroup @relation(fields: [adgroupId], references: [id], onDelete: Cascade)

  @@index([adgroupId])
}

model AdExtension {
  id            String            @id @default(cuid())
  ownerId       String // adgroupId 또는 campaignId 등
  ownerType     String            @default("adgroup")
  nccExtId      String            @unique
  type          AdExtensionType
  payload       Json
  periodStart   DateTime?
  periodEnd     DateTime?
  inspectStatus InspectStatus     @default(pending)
  inspectMemo   String?
  status        AdExtensionStatus @default(on)
  raw           Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // P1: ownerType=adgroup 가정. 향후 폴리모픽 확장 시 owner relation은 명시적 join으로 처리.
  adgroup AdGroup? @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, type])
}

// =============================================================================
// 변경 이력 / 감사
// =============================================================================

model ChangeBatch {
  id             String            @id @default(cuid())
  userId         String?
  action         String // 예: "keyword.bulk_off", "ad.bulk_update"
  status         ChangeBatchStatus @default(pending)
  total          Int               @default(0)
  processed      Int               @default(0)
  summary        Json?
  // Lease (3.5절 동시 실행 방지)
  leaseOwner     String?
  leaseExpiresAt DateTime?
  attempt        Int               @default(0)
  cursor         String? // 진단용
  createdAt      DateTime          @default(now())
  finishedAt     DateTime?

  user  UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)
  items ChangeItem[]

  @@index([status, leaseExpiresAt])
  @@index([userId])
}

model ChangeItem {
  id             String           @id @default(cuid())
  batchId        String
  targetType     String // "Keyword" / "Ad" / "AdExtension" / "Campaign" / "AdGroup"
  targetId       String? // 네이버 nccId 또는 내부 id (CREATE 전엔 null 가능)
  before         Json?
  after          Json?
  status         ChangeItemStatus @default(pending)
  error          String?
  idempotencyKey String // 사용자 externalId 또는 자체 생성
  attempt        Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  batch ChangeBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, idempotencyKey])
  @@index([batchId, status])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  targetType String
  targetId   String?
  before     Json?
  after      Json?
  ts         DateTime @default(now())

  user UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, ts])
  @@index([targetType, targetId])
}

// =============================================================================
// 알림 (P1)
// =============================================================================

model AlertRule {
  id          String   @id @default(cuid())
  type        String // budget_burn / bizmoney_low / api_auth_error / inspect_rejected ...
  params      Json
  channelHint String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events AlertEvent[]
}

model AlertEvent {
  id        String           @id @default(cuid())
  ruleId    String
  payload   Json
  status    AlertEventStatus @default(pending)
  sentAt    DateTime?
  createdAt DateTime         @default(now())

  rule AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, createdAt])
}

// =============================================================================
// 성과 데이터
// =============================================================================
// P1은 Stats API + Redis 캐시로 대체 (자체 적재 X 또는 최소).
// StatDaily는 P1에서 모델만 선언. 적재 빈도/매출 조인은 P2에서 결정.
// conversions / revenue는 매출 조인 시점에 채움.

model StatDaily {
  id           String     @id @default(cuid())
  // F-9.1: advertiserId 비정규화 — refId는 level별로 다른 엔티티(campaign/adgroup/keyword)의
  // 내부 id이므로 광고주 격리 / 단일 필터 KPI / RLS 단순화 위해 직접 보존.
  // 적재 시 refId의 owner advertiser를 resolve하여 함께 채운다 (NOT NULL).
  advertiserId String
  date         DateTime   @db.Date
  level        StatLevel
  refId        String // campaignId / adgroupId / keywordId (네이버 nccId 또는 내부 id 통일)
  device       StatDevice
  impressions  Int        @default(0)
  clicks       Int        @default(0)
  cost         Decimal    @default(0) @db.Decimal(14, 2)
  avgRnk       Decimal?   @db.Decimal(5, 2)
  // 매출/전환 조인은 P2 후속 (CRM·매출 시스템 연동 시점)에 채움
  conversions  Int?
  revenue      Decimal?   @db.Decimal(14, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  advertiser Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  @@unique([date, level, refId, device])
  // 광고주 + 기간 KPI 카드(F-7.1) / TOP-N 차트(F-7.2)
  @@index([advertiserId, date])
  // 광고주 + 레벨별 차트 (예: 광고주 N의 keyword level 30일 추이)
  @@index([advertiserId, level, date])
  // 적재 / 디버깅용 — 기존 인덱스 유지
  @@index([date, level, refId])
}

// F-9.2 — 시간별 적재 (P2 두 번째 적재 모델)
// 네이버 Stats API 의 시간별 데이터는 7일 보존 한계 → 자체 누적 필요.
// hh24 breakdown 으로 매시간 폴링 + upsert. KST 기준 (date Date + hour Int 0..23)
// 으로 시간대 정합성 단순화 (단일 timestamp 컬럼은 timezone 처리 모호함 회피).
//
// device 정책:
//   - 본 모델은 ALL 단일 디바이스로만 적재 (hh24 + pcMblTp 동시 breakdown 미지원).
//   - 시간×디바이스 분해가 필요해지면 device 컬럼은 그대로 두고 PC/MOBILE 적재 추가.
//   - device 컬럼을 unique 키에 포함해 두어 향후 확장 안전.
//
// retention 권고:
//   - 광고주 N × 24시간 × ~5,000 ref × 1 device(ALL) → 1년 후 ≈ 수억~수십억 rows.
//   - 90일 보관 cleanup cron 후속 PR 권고 (비딩 정책 / 알림 lookback 30일 가정).
//   - 본 PR 은 모델만 — retention 작업은 운영 부하 측정 후 결정.
model StatHourly {
  id           String     @id @default(cuid())
  // F-9.1 StatDaily 와 동일 비정규화 패턴 — 광고주 단일 필터 / Cascade / RLS 단순화.
  advertiserId String
  date         DateTime   @db.Date // KST 기준 일자
  hour         Int // 0..23 (KST 시각)
  level        StatLevel
  refId        String // campaignId / adgroupId / keywordId (네이버 nccId 또는 내부 id)
  device       StatDevice // 본 PR: 'ALL' 만 사용 (hh24 단일 breakdown). 향후 PC/MOBILE 분리 적재 시 enum 그대로 사용.
  impressions  Int        @default(0)
  clicks       Int        @default(0)
  cost         Decimal    @default(0) @db.Decimal(14, 2)
  // F-9.4 1시간 주기 갱신 입력 (Keyword.recentAvgRnk 갱신 원천 — keyword level 행 한정)
  recentAvgRnk Decimal?   @db.Decimal(5, 2)
  // 매출/전환 / raw 는 본 PR 비포함 — 시간별 매출 조인은 P2 후속 결정
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  advertiser Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  // 시간×레벨×ref×device 한 행 보장 (upsert 키)
  @@unique([date, hour, level, refId, device])
  // 광고주 + 시간 윈도 read (F-9.2 ingest cursor / F-7 시간별 차트)
  @@index([advertiserId, date, hour])
  // 광고주 + 레벨별 시간 차트 (예: 광고주 N의 keyword level 24h 추이)
  @@index([advertiserId, level, date, hour])
  // 적재 / 디버깅용 — 특정 ref 의 시간 추이
  @@index([date, hour, level, refId])
}

// =============================================================================
// F-10 — Estimate API 캐시 (P2 비딩 시뮬레이터)
// =============================================================================
// 3개 endpoint 결과를 단일 테이블에 type 분기로 저장. 30분 TTL.
//
// 키 설계:
//   공통 키        : advertiserId + keywordId + device + type
//   endpoint별 키  :
//     - average_position : position (1..5)        → bid     = 0 sentinel
//     - exposure_minimum : 추가 키 없음           → position=0, bid=0 sentinel
//     - performance_bulk : bid (특정 후보 입찰가) → position = 0 sentinel
//
//   sentinel 0 사용 근거:
//     Postgres 의 NULL 은 unique 비교에서 서로 다르게 취급되어, NULL 을 키 일부로 두면
//     동일 (advertiser, keyword, device, type) 의 row 가 중복 삽입될 수 있음. 0 을
//     "N/A" sentinel 로 강제하면 unique 위반이 정확히 캐시 hit 으로 작동. position 은
//     1..5 만 의미 있고 bid 는 양수만 의미 있으므로 0 충돌 없음.
//
// result Json 의 shape (passthrough):
//   - average_position : { bid: number }
//   - exposure_minimum : { bid: number }
//   - performance_bulk : { impressions: number, clicks: number, cpc: number, cost: number }
//   엔드포인트 응답 변경에 대비해 schema 강제 X — 호출부에서 Zod 파싱.
//
// TTL:
//   expiresAt = createdAt + 30 min. read 시 lazy 만료 검사 (expiresAt > now()).
//   만료 행 정리는 cleanup cron 후속 PR 권고 (StatHourly retention 패턴 동일).
//
// keywordId 는 내부 Keyword.id 사용 (FK Cascade) — nccKeywordId 가 아님.
// advertiserId 비정규화 (StatDaily / StatHourly F-9.x 패턴 일관) — RLS 단일 EXISTS.
model EstimateCache {
  id           String       @id @default(cuid())
  advertiserId String
  keywordId    String
  device       StatDevice // PC / MOBILE (estimate 는 디바이스 분리 호출). ALL 비사용.
  type         EstimateType
  position     Int          @default(0) // 1..5 (average_position 만), 그 외 type 은 0 sentinel
  bid          Int          @default(0) // performance_bulk 만 양수, 그 외 type 은 0 sentinel
  result       Json // endpoint 별 shape (위 주석)
  expiresAt    DateTime // createdAt + 30 min
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  advertiser Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  keyword    Keyword    @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  // 캐시 hit 키 — 위 sentinel 정책 덕에 NOT NULL 컬럼 unique 깔끔.
  @@unique([advertiserId, keywordId, device, type, position, bid])
  // cleanup cron (만료 행 삭제) 효율
  @@index([expiresAt])
  // 키워드 단위 일괄 무효화 (예: 키워드 입찰가 변경 시 해당 키워드 캐시 전체 drop)
  @@index([keywordId])
}

// =============================================================================
// F-11.1 — 비딩 정책 (P2)
// =============================================================================
// 키워드 단위 목표 노출 순위 정책. 디바이스(PC/MOBILE)는 별도 row 로 분리:
//   - StatDevice enum 재사용 (PC / MOBILE 만 사용. ALL 은 본 모델에서 비사용 — 코드 정책)
//   - UNIQUE [keywordId, device] → 같은 키워드+device 조합당 정책 1개
//   - "PC 1위 / MOBILE 3위" 같은 분리 정책은 row 2개로 표현
//   - 그룹 단위 정책은 P2 후속 (별도 모델 또는 ownerType 도입)
//
// 자동 조정 흐름 (F-11.2 후속):
//   1) 매시간 cron 이 enabled=true policies 픽업
//   2) StatHourly recentAvgRnk 와 targetRank 비교 → bidAmt 조정량 산출
//   3) Guardrail (F-11.5: maxBid / minBid / 일 변경 한도) 적용
//   4) Kill Switch (F-11.6: Advertiser.biddingKillSwitch) 검사 → skip
//   5) ChangeBatch 생성 → SA bidAmt update → OptimizationRun 적재
//
// advertiserId 비정규화 (F-9.x / F-10 패턴 일관) — RLS 단일 EXISTS, Cascade 단순화.
// 적재 시 keywordId owner advertiser resolve 책임은 backend 측 (호출부 보장).
model BiddingPolicy {
  id           String     @id @default(cuid())
  advertiserId String // F-9.x 비정규화 — RLS 단일 EXISTS / 광고주 단일 필터
  keywordId    String // 내부 Keyword.id (nccKeywordId 아님, FK Cascade)
  device       StatDevice // PC / MOBILE 만 사용 (ALL 비사용 — 코드 정책)
  targetRank   Int // 목표 노출 순위 (1..10 권고, 호출부 Zod 검증)
  maxBid       Int? // 자동 조정 상한 (원). null = 미제한
  minBid       Int? // 자동 조정 하한 (원). null = 미제한
  enabled      Boolean    @default(true) // false 면 자동 조정 대상 제외 (수동 보존)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  advertiser Advertiser        @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  keyword    Keyword           @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  runs       OptimizationRun[]

  // 같은 키워드+device 정책은 1개 — 정책 충돌 방지 (PC/MOBILE 각각 row)
  @@unique([keywordId, device])
  // 광고주별 활성 정책 픽업 (F-11.2 cron: 매시간 enabled=true 스캔)
  @@index([advertiserId, enabled])
  // 키워드 단위 정책 lookup (정책 편집 / 삭제 / drift 검사)
  @@index([keywordId])
}

// =============================================================================
// F-11.7 — 자동 비딩 실행 로그 (P2)
// =============================================================================
// 자동 비딩 / 수동 1회 변경 / 롤백 등 비딩 액션 단위 결과 기록.
// trigger / result 는 string 으로 시작 (enum 승격은 후속 — 운영 중 케이스 확정 후).
//
// trigger 후보 (코드 상수 / Zod literal union):
//   - "auto"     : F-11.2 매시간 cron 자동 조정
//   - "manual"   : 사용자가 정책 화면에서 1회 적용
//   - "rollback" : F-6.x 롤백 흐름이 비딩 정책 변경을 되돌림
//
// result 후보:
//   - "success"               : SA bidAmt update 성공
//   - "skipped_guardrail"     : Guardrail 한도 초과로 변경 미적용
//   - "skipped_killswitch"    : Kill Switch ON 으로 차단
//   - "failed"                : SA API 호출 실패 (errorMessage 채움)
//
// before / after 스냅샷:
//   - { bidAmt, recentAvgRnk, targetRank } 등 — Json passthrough.
//   - 매출/전환 사후 분석은 별도 ETL (본 모델은 변경 시점 스냅샷만).
//
// policyId nullable: 수동 1회 변경 (정책 없이 사용자가 1회 입찰가 변경) 케이스.
//   policy 삭제 시 SetNull — 로그는 유지 (감사 추적).
//
// retention:
//   광고주 N × 정책 M × 시간당 24 row → 1년 후 수십만~수백만 rows.
//   retention cron 후속 PR (StatHourly / EstimateCache 패턴 일관) — 본 PR 모델만.
model OptimizationRun {
  id           String   @id @default(cuid())
  advertiserId String // F-9.x 비정규화 — 광고주 단일 필터 / RLS 단순화
  policyId     String? // null = 정책 없는 수동 1회 변경 (또는 정책 삭제 후 SetNull)
  trigger      String // "auto" / "manual" / "rollback" (enum 승격은 후속)
  before       Json? // 변경 전 스냅샷 ({ bidAmt, recentAvgRnk, ... })
  after        Json? // 변경 후 스냅샷
  result       String // "success" / "skipped_guardrail" / "skipped_killswitch" / "failed"
  errorMessage String?  @db.VarChar(500)
  triggeredAt  DateTime @default(now())

  advertiser Advertiser     @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  policy     BiddingPolicy? @relation(fields: [policyId], references: [id], onDelete: SetNull)

  // 광고주별 시간 윈도 read (실행 로그 페이지 — 최근 24h / 7d 필터)
  @@index([advertiserId, triggeredAt])
  // 정책별 실행 추이 (정책 상세 페이지 — 해당 정책의 최근 실행 결과)
  @@index([policyId, triggeredAt])
  // 실패 / 차단 trace (운영 모니터링 — failed / skipped_* 만 빠르게 조회)
  @@index([result, triggeredAt])
}

// =============================================================================
// F-11.4 — 타겟팅 가중치 룰 (P2)
// =============================================================================
// 광고주 단위 시간대 / 지역 / 디바이스 입찰 가중 (multiplier).
// 본 PR 단순화 결정:
//   1) 광고주 1:1 (advertiserId @unique) — 정책별(BiddingPolicy) override 는 후속.
//      "PC 1.2x / MOBILE 1.0x" 같은 광고주 전역 가중을 cron 이 모든 활성 정책에 곱함.
//   2) 단일 row + JSON 컬럼 — 168(시간) + 17(시도) + 2(디바이스) ≈ 187 entry 를
//      별도 row 정규화하면 row 수만 부풀고 read 패턴은 항상 "광고주 1행 전체" 이므로
//      JSON passthrough 가 더 단순 (운영 stable 후 재검토).
//   3) 지역 weight (regionWeights) 는 모델만 보유 — 캠페인 노출 지역 정보가 SA API
//      응답에 섞여 들어오지 않으므로 자동 비딩 대상 키워드의 지역 매칭이 불가.
//      UI 시각화 / 향후 보고서 용도. 자동 비딩에서는 무시.
//
// JSON 키 형식:
//   hourWeights   : { "{day}-{hour}": Decimal }
//                   day  : "mon" | "tue" | "wed" | "thu" | "fri" | "sat" | "sun"
//                   hour : 0..23 (KST)
//                   예) { "mon-0": 1.0, "mon-9": 1.5, "fri-22": 0.7 } (168 키 max)
//                   누락 키는 defaultWeight 적용.
//   regionWeights : { "{시도코드 2자리}": Decimal }   예) { "11": 1.2, "26": 0.9 }
//                   본 PR 자동 비딩 미적용 — 모델만.
//   deviceWeights : { "PC" | "MOBILE": Decimal }       예) { "PC": 1.0, "MOBILE": 1.2 }
//
// weight 범위 (호출부 Zod 검증 — DB 는 default 만 강제):
//   - 운영 입력 권장: 0.1..3.0 (clamp)
//   - DB Decimal(4,2) 는 0..9.99 까지 허용 (오타 / 확장 여유)
//
// 자동 비딩 흐름 (F-11.x cron 후속):
//   1) cron 픽업 시 advertiser → TargetingRule 1행 lazy upsert (없으면 default 생성)
//   2) enabled=false 면 weight 적용 0 (defaultWeight 1.0 동등 — clamp 결과)
//   3) BiddingPolicy 가 산출한 baseBid 에 hourWeights[현재요일-시각] × deviceWeights[디바이스] 곱
//   4) Guardrail (F-11.5) 통과 시 SA bidAmt update
//
// advertiserId @unique 결정 근거:
//   - "광고주 전역 1:1" 명시적 강제 (어디서든 row 1개 보장)
//   - lookup 인덱스 자동 생성 (별도 @@index 불필요)
//   - 정책별 override 가 필요해지면 (advertiserId, scope) 복합 unique 로 후속 마이그레이션
model TargetingRule {
  id            String   @id @default(cuid())
  advertiserId  String   @unique // 광고주 1:1 — 본 PR 단순화. 정책별 override 후속.
  enabled       Boolean  @default(true) // 룰 자체 on/off (false 면 cron 이 weight 적용 스킵)
  defaultWeight Decimal  @default(1.0) @db.Decimal(4, 2) // JSON 키 누락 시 적용 (운영 입력 0..3 권장)
  hourWeights   Json     @default("{}") // { "{day}-{hour}": Decimal } — 168 키 max
  regionWeights Json     @default("{}") // { "{시도코드 2자리}": Decimal } — 본 PR 모델만 (자동 비딩 미적용)
  deviceWeights Json     @default("{}") // { "PC" | "MOBILE": Decimal }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  advertiser Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  // advertiserId @unique 가 lookup 인덱스 역할 동시 수행 — 추가 @@index 없음.
  // (광고주 횡단 활성 룰 카운트는 본 PR 비포함)
}

// =============================================================================
// P2 엔티티 (선언 보류 — 작업 시점에 추가)
// =============================================================================
// model RankObservation { ... } // 시간별 순위 관측 (StatHourly 와 통합 검토)
// model LlmCallLog      { ... } // LLM 호출 비용
